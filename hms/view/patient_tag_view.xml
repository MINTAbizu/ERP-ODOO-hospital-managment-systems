<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="patient_action_tag" model="ir.actions.act_window">
        <field name="name">Patient Tags</field>
        <field name="res_model">hospital.patient_tag</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="hospital_patient_tag_tree" model="ir.ui.view">
        <field name="name">hospital.patient_tag.view.tree</field>
        <field name="model">hospital.patient_tag</field>
        <field name="arch" type="xml">
            <tree string="Patient Tags">
                <field name="name"/>
            </tree>
        </field>
    </record>
</odoo>
