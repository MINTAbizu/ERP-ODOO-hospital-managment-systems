<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="patient_visits_action" model="ir.actions.act_window">
        <field name="name">Action Name</field>
        <field name="res_model">patient.visits</field>
        <field name="view_mode">list,form</field>
       
    </record>

    <record id="patient_visits_view_tree" model="ir.ui.view">
        <field name="name">patient.visits.view.tree</field>
        <field name="model">patient.visits</field>
        <field name="arch" type="xml">
        <field name="type">lisr</field>
            <list string="">
            <field name="patient_id" />
            <field name="doctor_id" />
            <field name="visit_type" />
            <field name="date_of_visited" />


            <field name="department_id" />
            <field name="chief_complaint" />
            <field name="diagnosis" />
            <field name="treatment_plan" />
            <field name="notes" />
                
            </list>
        </field>
    </record>

    <record id="patient_visits_view_form" model="ir.ui.view">
        <field name="name">patient.visits.view.form</field>
        <field name="model">patient.visits</field>
        <field name="arch" type="xml">
            <form string="">
            
            
                <sheet>
                    <group>
                    <field name="patient_id" />
                    <field name="doctor_id" />
                    <field name="visit_type" />
                    <field name="date_of_visited" />


                    
                        
                    </group>
                    <group >
                    <field name="department_id" />
                    <field name="chief_complaint" />
                    <field name="diagnosis" />
                    <field name="treatment_plan" />
                    <field name="notes" />
                        
                    </group>
                </sheet>

                
            </form>
        </field>
    </record>

</odoo>
