<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_patientAppointment_action" model="ir.actions.act_window">
        <field name="name">patientappointment</field>
        <field name="res_model">hospital.patient.appointment</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="hospital_patient_appointment_view_list" model="ir.ui.view">
        <field name="name">hospital.patientAppointment.view.list</field>
        <field name="model">hospital.patient.appointment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="reference"/>
                <field name="patient_id"/>
                <field name="patientAppointment_date"/>
            </tree>
        </field>
    </record>

    <record id="hospital_patientAppointment_view_form" model="ir.ui.view">
        <field name="name">hospital.patientAppointment.view.form</field>
        <field name="model">hospital.patient.appointment</field>
        <field name="arch" type="xml">
            <form>
            
            <header>
           

            <button name="action_confirem" type="object"  string="confirm"  invisible="status_bar !='draft'"  class="oe_highlight" />
            <button name="action_draft" type="object"  string="draft"/>
            <!-- <button name="action_cancels" type="object"  string="canceld" invisible="status_bar !='done'"  class="oe_highlight"/> -->
            <button name="action_done" type="object"  string="done"  invisible="status_bar !='ongoing'"  class="oe_highlight"/>
            <button name="action_ongoing" type="object"  string="ongoing"  invisible="status_bar !='confirmed'" class="oe_highlight"/>
            <!-- <button name="action_paid" type="object"  string="paid"/> -->
            
            
             <field name="status_bar" widget="statusbar"/>  

            </header>
                <sheet>
                    <group>

                        <group> 
                            <field name="reference"/>
                    
                        </group>
                        <group> 
                                <field name="patient_id"/>
                                <field name="patientAppointment_date"/>
                        </group>
                       
                        <group>
                            <group> 
                            <field name="Appintment_not"/>
                            
                            </group>
                        
                    
                            
                        </group> 
                    </group> 
                    <field name="appoinetment_line_ids">
                        <tree>
                            <field name="product_id"/>
                            <field name="product_qty"/>
                        </tree>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>



