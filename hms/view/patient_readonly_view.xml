<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hospital_patient_view_listreadonly" model="ir.ui.view">
        <field name="name">hospital.patient.view.readonly.list</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="last_name" optional="show"/>
                <field name="dob" optional="hide"/>
                <field name="gender" optional="show"/>
                <field name="address" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="hospital_patient_viewreadonly_form" model="ir.ui.view">
        <field name="name">hospital.patient.view.readonly.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="last_name"/>
                        </group>
                        <group>
                            <field name="dob"/>
                            <field name="gender"/>
                        </group>
                        <group>
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>

