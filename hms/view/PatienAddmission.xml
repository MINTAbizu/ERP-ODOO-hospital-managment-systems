<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="patient_addmission_action" model="ir.actions.act_window">
        <field name="name">Action Name</field>
        <field name="res_model">patient_addmission</field>
        <field name="view_mode">list,form</field>
       
    </record>

    <record id="patient_addmission_view_tree" model="ir.ui.view">
        <field name="name">patient.addmission.view.tree</field>
        <field name="model">patient.addmission</field>
        <field name="arch" type="xml">
        <field name="type">list</field>
            <tree string="">
            <field name="patient_id" />
      
            <field name="discharge_date" />
            <field name="admission_date" />
            <field name="bed_id" />
           
            
                
            </tree>
        </field>
    </record>

    <record id="patient_addmission_view_form" model="ir.ui.view">
        <field name="name">patient.addmission.view.form</field>
        <field name="model">patient.addmission</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                    
                        <field name="bed_id" />
                        <field name="addmisiion" />
                        
                        <field name="doctor_id" />
                        <field name="department" />
                                    
                    </group>
                    <group>
                                <field name="patient_id" />
                
                        <field name="discharge_date" />
                        <field name="admission_date" />
                        <field name="bed_id" />
                        
                                    
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
