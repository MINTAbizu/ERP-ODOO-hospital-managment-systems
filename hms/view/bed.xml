<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="bed_management_action" model="ir.actions.act_window">
        <field name="name">Action Name</field>
        <field name="res_model">bed._management</field>
        <field name="view_mode">list,form</field>
        
    </record>

    <record id="bed_management_view_tree" model="ir.ui.view">
        <field name="name">bed.management.view.tree</field>
        <field name="model">bed.management</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="">
             
             <field name="patient_id" />
             <field name="bed_type" />
             <field name="bed_status" />
             <field name="bed_capacity" />

             <field name="name" />
             <field name="ward_id" />
             <field name="location_bed" />
             
                
            </list>
        </field>
    </record>

    <record id="bed_management_view_form" model="ir.ui.view">
        <field name="name">bed.management.view.form</field>
        <field name="model">bed.management</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                  

                        <field name="name" />
                        <field name="ward_id" />
                        <field name="location_bed" />
                        
                    </group>
                    <group>
                        <field name="patient_id" />
                        <field name="bed_type" />
                        <field name="bed_status" />
                        <field name="bed_capacity" />

                
                        
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
