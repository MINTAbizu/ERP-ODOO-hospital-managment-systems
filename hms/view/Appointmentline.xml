<?xml version="1.0" encoding="utf-8"?>
<odoo>

    
    <record id="hospital_patientAppointment_line_action" model="ir.actions.act_window">
        <field name="name">Appointment Lines</field>
        <field name="res_model">hospital.patient.appointment_line</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="hospital_patient_appointment_line_view_tree" model="ir.ui.view">
        <field name="name">hospital.patient.appointment_line.view.tree</field>
        <field name="model">hospital.patient.appointment_line</field>
        <field name="arch" type="xml">
            <tree string="">
            <field name="appointment_id" />
            <field name="product_id" />
            <field name="product_qty" />
                
            </tree>
        </field>
    </record>

</odoo>
